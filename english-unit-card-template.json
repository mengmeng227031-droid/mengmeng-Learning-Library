          "B. cousin"
        ],
        "answer": "grandma"
      }
    ],
    "homework": "Use \"Is this/that your ___?\" to ask and answer with your family.",
    "dialogue": [
      {
        "speaker": "A",
        "text": "Is this your sister?"
      },
      {
        "speaker": "B",
        "text": "Yes, it is."
