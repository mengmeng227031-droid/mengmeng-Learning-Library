      "headerNumberFill": "#FFE7A8",
      "headerTitleColor": "#FF5A2F",
      "shadow": "0 4px 12px rgba(255, 200, 61, 0.16)"
    },
    "illustrationStyle": "cute children textbook illustration, soft rounded edges, bright clean colors, warm classroom workbook style, white or transparent background, no watermark, no text"
  },
  "dataSchema": {
    "unitTitle": "string",
    "grade": "string",
    "lesson": "string",
    "keywords": [
      {
        "word": "string",
        "phonetic": "optional string",
        "imagePrompt": "string",
        "image": "asset path after generation"
      }
    ],
    "keySentences": [
      "string"
    ],
    "talk": [
      {
        "speaker": "string",
        "text": "string"
      }
    ],
    "practice": [
      {
        "imagePrompt": "string",
        "image": "asset path after generation",
        "options": [
          "string"
        ],
        "answer": "string"
      }
    ],
    "homework": "string",
    "dialogue": [
      {
        "speaker": "string",
        "text": "string"
      }
    ],
    "reading": {
      "title": "string",
      "lines": [
        "string"
      ],
      "scenePrompt": "string",
      "image": "asset path after generation"
    },
    "grammar": [
      {
        "pattern": "string",
        "meaning": "string"
      }
    ],
    "exercise": [
      {
        "imagePrompt": "string",
        "image": "asset path after generation",
        "answer": "string"
      }
    ],
    "summaryChecks": [
      "string"
    ],
    "selfRating": {
      "maxStars": "number",
      "value": "number"
    }
  },
  "markdownMapping": {
    "unitTitle": "first H1, or front matter field unitTitle",
    "grade": "front matter grade, default K2",
    "lesson": "front matter lesson",
    "keywords": "table or list under headings: Key Words, 核心单词, 单词",
    "keySentences": "list under headings: Key Sentences, 核心句型, 句子",
    "talk": "speaker lines under headings: Let's Talk, 课文对话",
    "practice": "table or list under headings: Practice, 练习",
    "homework": "paragraph under headings: Homework, 作业",
    "dialogue": "speaker lines under headings: Dialogue, 对话练习",
    "reading": "title and lines under headings: Let's Read, 一起阅读",
    "grammar": "pattern list under headings: Grammar Focus, 语法小贴士",
    "exercise": "image-answer list under headings: Exercise, 练一练",
    "summaryChecks": "checkbox list under headings: Summary, 本课小结"
  },
