      "type": "softPaper",
      "color": "#FFF9E8",
      "texture": "warm cream watercolor paper with subtle corner stains"
    },
    "border": {
      "color": "#FFC83D",
      "width": 3,
      "radius": 24
    }
  },
  "brandStyle": {
    "palette": {
      "blue": "#4D8BFF",
      "pink": "#FF6EC7",
      "yellow": "#FFC83D",
      "cyan": "#37D2C6",
