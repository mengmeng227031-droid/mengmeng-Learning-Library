  "imageGenerationPolicy": {
    "wordImagePromptTemplate": "A cute children textbook illustration of {word}, single clear subject, easy for K2 children to recognize, soft rounded shape, bright clean colors, white or transparent background, no letters, no caption, no watermark.",
    "personWordPromptTemplate": "A cute children textbook illustration representing {word}, friendly family member portrait, waist-up, soft rounded shape, bright clean colors, white or transparent background, no letters, no caption, no watermark.",
    "scenePromptTemplate": "A cute children textbook illustration of {scene}, warm classroom workbook style, simple composition, no letters, no caption, no watermark.",
    "useImage2For": [
      "word illustrations",
      "practice illustrations",
      "dialogue scene",
      "reading scene"
    ],
    "styleConsistency": "Generate all illustrations in the same workbook style and keep the subjects isolated unless the slot is a scene."
  },
  "batchOutput": {
    "fileNamePattern": "english-{lessonSlug}-{side}.png",
    "assetDirPattern": "assets/generated/english/{lessonSlug}/",
    "jsonDataPattern": "data/english/{lessonSlug}.json",
    "sides": [
      "A",
      "B"
    ]
  },
